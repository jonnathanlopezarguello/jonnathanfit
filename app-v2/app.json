{
  "expo": {
    "name": "Jonnathan Fit",
    "slug": "jonnathan-fit",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#121211"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jonnathanfit.app"
    },
    "android": {
      "package": "com.jonnathanfit.app",
      "adaptiveIcon": {
        "backgroundColor": "#121211"
      },
      "permissions": [
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.READ_DISTANCE",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED"
      ]
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 35,
            "minSdkVersion": 26
          }
        }
      ],
      [
        "react-native-health-connect",
        {
          "requestPermissionsRationale": "Jonnathan Fit necesita acceder a tus datos de salud para sincronizar con tu Galaxy Fit3"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "54c33850-6930-4f65-97d6-509a6fa13120"
      }
    }
  }
}
